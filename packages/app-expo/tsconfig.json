{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "index.js"],
  "exclude": [
    "src/editor/web-editor.tsx",
    "src/editor/highlight-ref-extension.ts",
    "node_modules"
  ]
}
